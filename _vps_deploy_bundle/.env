# ==================== DEPLOYMENT ====================
# SUPPORTS: Exness, Binance, PXBT (DEMO/LIVE switchable via ENVIRONMENT variable)
#
# FOR DEMO MODE:
#   1. Set ENVIRONMENT=DEMO
#   2. EXNESS: Backend uses Account 298997455, Server: Exness-MT5Trial9
#   3. BINANCE: Set BINANCE_DEMO_API_KEY/BINANCE_DEMO_API_SECRET (testnet credentials)
#   4. Run: python multi_broker_backend_updated.py
#   5. Check logs for: "[DEMO] Mode Active..." with account details
#
# FOR LIVE MODE:
#   1. Set ENVIRONMENT=LIVE
#   2. EXNESS: Update EXNESS_ACCOUNT and EXNESS_PASSWORD
#   3. BINANCE: Update BINANCE_API_KEY and BINANCE_API_SECRET
#   4. Run: python multi_broker_backend_updated.py
#   5. Check logs for: "[LIVE] Mode Active..." with account details
#   6. Verify trades appear in each broker's portal/terminal
#
# HOW TO VERIFY TRADES ARE EXECUTING:
#   EXNESS DEMO:
#     - Open Exness MT5 Demo terminal
#     - Go to: Terminal → Trade History tab
#     - Trades appear within 1-2 seconds of bot execution
#
#   EXNESS LIVE:
#     - Open Exness portal (my.exness.com/account) → Trade History
#     - Or Exness MT5 Live terminal → Terminal → Trade History
#
#   BINANCE DEMO:
#     - Open Binance Testnet (https://testnet.binance.vision)
#     - Go to: Wallet → Trade History or Orders
#
#   BINANCE LIVE:
#     - Open Binance.com
#     - Go to: Wallet → Trade History or Orders
#
# TROUBLESHOOTING:
#   - No trades appearing? Check backend logs for connection errors
#   - Wrong broker? Verify ENVIRONMENT matches which broker credentials you provided
#   - Check that MT5/API credentials are still valid (sometimes passwords expire)
#   - Ensure ENVIRONMENT=LIVE uses the LIVE credentials, not DEMO
#
# Generated: 2026-03-20
# Status: Multi-Broker DEMO/LIVE Support (Exness, Binance, PXBT)

# ==================== BOT PERSISTENCE & AUTO-RESTART ====================
# Enable automatic bot restart on backend startup
# Set to 'true' for persistent trading (bots resume after backend restart)
# Set to 'false' to start with no bots running
AUTO_RESTART_BOTS_ON_STARTUP=true

# ==================== CONCURRENT ACTIVE BOT CAP ====================
# Global active-trading cap enforced by /api/bot/start.
# Set high for Binance scaling (Binance bots are lightweight REST-only, no MT5).
# MT5 bots are subject to terminal capacity; Binance bots can run thousands concurrently.
MAX_CONCURRENT_ACTIVE_BOTS=50

# ==================== WORKER POOL SCALING (100+ Users) ====================
# MT5 worker subprocesses. Each worker gets its own MT5 terminal.
# 0 = disabled (legacy single-process mode, default)
# 3 = 3 workers x 35 bots/worker = 105 concurrent bots
# 5 = 5 workers x 35 bots/worker = 175 concurrent bots
WORKER_COUNT=0
WORKER_COMMAND_POLL_INTERVAL=5
MAX_BOTS_PER_WORKER=1

# ==================== BINANCE SCALING (5000 Users) ====================
# Dedicated Binance worker processes (separate from MT5 workers)
# Each worker runs 500 Binance bot threads (I/O-bound, GIL-safe)
# 5 workers x 500 bots = 2500 concurrent bots = 5000 users @ 10% concurrency
BINANCE_WORKER_COUNT=2
MAX_BOTS_PER_BINANCE_WORKER=500

# Redis URL for shared Binance price cache (written by binance_market_data.py)
# Start Redis first: see setup_binance_scaling.ps1
REDIS_URL=redis://localhost:6379/0
# SQLite busy timeout in milliseconds (2 minutes for concurrent bot writes)
SQLITE_BUSY_TIMEOUT_MS=30000
WAITRESS_THREADS=6
# Postgres connection pool size (min=2, max=PG_POOL_MAX)
# Increased to 200 to handle Exness (100) + Binance (1000+) concurrent connections
PG_POOL_MAX=200

# Binance WebSocket symbols tracked by binance_market_data.py (comma-separated)
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT,DOGEUSDT,AVAXUSDT,MATICUSDT,LINKUSDT

# ==================== REST TRADING (Phase 2 - 500+ Users) ====================
# MetaAPI: Cloud-hosted MT5 REST API — trades via HTTP instead of local MT5 terminal
# Sign up at https://metaapi.cloud — free tier: 1 account, paid: unlimited
# This is what eliminates the MT5 single-process bottleneck
METAAPI_TOKEN=
METAAPI_REGION=new-york

# Prefer REST trading for supported brokers (Exness, PXBT)

# ==================== POSTGRESQL DATABASE (Enterprise Scale) ====================
# PostgreSQL connection for 500-5,000 users
# Migrated from SQLite on May 27, 2026
DATABASE_BACKEND=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=zwesta_trading
POSTGRES_USER=zwesta_admin
POSTGRES_PASSWORD=Zwesta@Trading2026!

# Full connection string (for SQLAlchemy compatibility)
# Password URL-encoded: @ = %40, ! = %21
DATABASE_URL=postgresql://zwesta_admin:Zwesta%40Trading2026%21@localhost:5432/zwesta_trading

# ==================== BROKER CAPACITY LIMITS ====================
# Maximum concurrent users per broker type
# Exness: Limited by MT5 terminal capacity (10 users per terminal)
#         With 2 MT5 terminals, support 20 Exness users
# Binance: API-based, scales to 5000+ users (limited by CPU/RAM, not software)
EXNESS_MAX_USERS=20
BINANCE_MAX_USERS=5000

# When true + MetaAPI token set: bots use REST API instead of local MT5
# When false or no token: falls back to local MT5 terminal (legacy mode)
PREFER_REST_TRADING=true

# ==================== REST PRICE FEED (Optional - reduces MT5 load) ====================
# Provides real-time prices via REST APIs instead of MT5 symbol_info_tick()
# Get free keys: https://twelvedata.com (800 req/day free) or https://alphavantage.co (25 req/day free)
# If both empty, prices come from MT5 terminal (still works, just slower)
TWELVE_DATA_KEY=
ALPHA_VANTAGE_KEY=

# ==================== SELF-HOSTED SOCKET BRIDGE (Free - No External Service) ====================
# Each MT5 terminal runs ZwestaTradeServer.mq5 EA on a unique port.
# Python backend sends trade commands via TCP socket to localhost.
# Format: broker:account:port,broker:account:port,...
# Example: Exness:298997455:8001,PXBT:1226483:8002
# Leave empty to disable (falls back to direct MT5 Python module)
SOCKET_BRIDGES=
# Auth token must match the EA's AuthToken input parameter
SOCKET_AUTH_TOKEN=zwesta


