# Zwesta Trading System - Environment Configuration
# Generated: May 27, 2026

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_BACKEND=postgres
DATABASE_URL=postgresql://zwesta_admin:Zwesta@Trading2026!@localhost:5432/zwesta_trading

# ============================================
# CAPACITY LIMITS
# ============================================
EXNESS_MAX_USERS=20
BINANCE_MAX_USERS=5000

# ============================================
# FLASK CONFIGURATION
# ============================================
FLASK_ENV=development
FLASK_DEBUG=True

# ============================================
# API CONFIGURATION
# ============================================
API_PORT=9000
ALLOWED_ORIGINS=*

# ============================================
# SECURITY (Generate new SECRET_KEY for production)
# ============================================
# SECRET_KEY=your-secret-key-here

# ============================================
# BROKER CONFIGURATION
# ============================================
# Add your broker API keys here when ready
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# EXNESS_LOGIN=
# EXNESS_PASSWORD=
# EXNESS_SERVER=

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
