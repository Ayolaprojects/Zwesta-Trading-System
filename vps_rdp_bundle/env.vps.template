# VPS environment template for Zwesta backend
# Copy to .env and replace placeholder values.

# Core app
FLASK_ENV=production
PORT=9000
ENVIRONMENT=DEMO

# Broker mode flags
PREFER_REST_TRADING=true
BINANCE_MARKET_DATA_MODE=auto
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT,DOGEUSDT,AVAXUSDT,MATICUSDT,LINKUSDT
BINANCE_WORKER_COUNT=0
MAX_BOTS_PER_BINANCE_WORKER=500
MAX_CONCURRENT_BINANCE_BOTS=5000
EXNESS_MAX_USERS=20
BINANCE_MAX_USERS=999999

# Database (use separate VPS database for isolation)
DATABASE_URL=postgresql://USERNAME:PASSWORD@127.0.0.1:5432/zwesta_trading_vps

# Redis (optional but recommended)
REDIS_URL=redis://127.0.0.1:6379/0

# Security
JWT_SECRET_KEY=REPLACE_WITH_STRONG_SECRET
SESSION_SECRET_KEY=REPLACE_WITH_STRONG_SECRET

# Binance credentials
BINANCE_API_KEY=REPLACE_WITH_BINANCE_API_KEY
BINANCE_API_SECRET=REPLACE_WITH_BINANCE_API_SECRET
BINANCE_DEMO_API_KEY=REPLACE_WITH_BINANCE_DEMO_API_KEY
BINANCE_DEMO_API_SECRET=REPLACE_WITH_BINANCE_DEMO_API_SECRET
BINANCE_WALLET_ADDRESS=REPLACE_WITH_BINANCE_WALLET_ADDRESS
BINANCE_WALLET_NETWORK=TRX

# Binance spot fee/edge guards (protect net profitability after fees)
# Typical Binance spot fee is around 0.1% per side (0.001).
BINANCE_SPOT_FEE_RATE=0.001
# Require net exit edge above fees + minimum cushion (percentage of exit notional).
BINANCE_SPOT_MIN_NET_EXIT_PCT=0.12
# Require at least this net USDT gain unless urgent exit signal is present.
BINANCE_SPOT_MIN_NET_EXIT_AMOUNT=1.5
# Reduce churn by holding a minimum time before non-urgent exits.
BINANCE_SPOT_MIN_HOLD_MINUTES=5
# Keep false for capital protection; true allows loss exits when other logic asks to exit.
BINANCE_SPOT_ALLOW_LOSS_EXIT=false

# Exness live credentials
EXNESS_ACCOUNT=REPLACE_WITH_EXNESS_ACCOUNT
EXNESS_PASSWORD=REPLACE_WITH_EXNESS_PASSWORD
EXNESS_SERVER=Exness-MT5Real27
EXNESS_PATH=C:\Program Files\MetaTrader 5 EXNESS\terminal64.exe

# Exness demo credentials
EXNESS_DEMO_ACCOUNT=REPLACE_WITH_EXNESS_DEMO_ACCOUNT
EXNESS_DEMO_PASSWORD=REPLACE_WITH_EXNESS_DEMO_PASSWORD
EXNESS_DEMO_SERVER=Exness-MT5Trial9
EXNESS_DEMO_PATH=C:\Program Files\MetaTrader 5 EXNESS\terminal64.exe
EXNESS_LIVE_PATH=C:\Program Files\MetaTrader 5 EXNESS\terminal64.exe

# Broker/runtime related
ZWESTA_SKIP_PYTHON_REEXEC=1
MT5_STARTUP_WARMUP=0

# If using live mode on VPS, set this carefully:
# ENVIRONMENT=LIVE
